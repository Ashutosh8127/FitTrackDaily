{
  "manifest_version": 1,
  "name": "FitTrack Daily",
  "version": "1.0",
  "description": "Daily fat-loss tracker: protein, calories, steps, sleep, mood, weekly progress — veg & non-veg, any shift.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FitTrack Daily"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}